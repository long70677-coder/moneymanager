@* 空狀態：置中、柔和大圖示、靜音文字 *@
<div class="flex flex-col items-center justify-center py-16 text-center">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-b from-[#F3F4F6] to-[#E5E7EB] flex items-center justify-center mb-4 ring-1 ring-[#E5E7EB] shadow-inner">
        <span class="material-symbols-outlined text-[36px] text-[#9CA3AF]" style="font-variation-settings:'FILL' 0,'wght' 300">@Icon</span>
    </div>
    <p class="text-[#374151] font-medium">@Title</p>
    @if (!string.IsNullOrEmpty(Hint))
    {
        <p class="text-sm text-[#6B7280] mt-1.5 max-w-md leading-relaxed">@Hint</p>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "manage_search";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Hint { get; set; }
}
