<script>
        // Simple toggle interaction logic for demonstration
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.querySelector('[role="switch"]');
            const toggleKnob = toggleBtn.querySelector('span');
            const statusLabel = document.querySelector('.bg-surface-variant.text-on-surface-variant');

            toggleBtn.addEventListener('click', () => {
                const isChecked = toggleBtn.getAttribute('aria-checked') === 'true';
                
                if (!isChecked) {
                    toggleBtn.setAttribute('aria-checked', 'true');
                    toggleBtn.classList.remove('bg-outline-variant');
                    toggleBtn.classList.add('bg-action-blue');
                    toggleKnob.classList.add('translate-x-5');
                    
                    statusLabel.textContent = 'Confirmed';
                    statusLabel.classList.remove('bg-surface-variant', 'text-on-surface-variant');
                    statusLabel.classList.add('bg-success-bg', 'text-success-text', 'border-success-text');
                } else {
                    toggleBtn.setAttribute('aria-checked', 'false');
                    toggleBtn.classList.remove('bg-action-blue');
                    toggleBtn.classList.add('bg-outline-variant');
                    toggleKnob.classList.remove('translate-x-5');
                    
                    statusLabel.textContent = 'Unconfirmed';
                    statusLabel.classList.remove('bg-success-bg', 'text-success-text', 'border-success-text');
                    statusLabel.classList.add('bg-surface-variant', 'text-on-surface-variant');
                }
            });
        });
    </script>
</body></html>
